# Copy to <repo>/.env and chmod 600. File lives at the project root
# (gitignored) and is the only place credentials are kept on disk.
# Access token: generate fresh from Dhan web portal each morning (24h TTL).
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Optional overrides (defaults shown)
# EMRB_STATE_DIR=~/.claude-equity-momentum
# EMRB_WEB_HOST=127.0.0.1
# EMRB_WEB_PORT=8766
# EMRB_TIMEZONE=Asia/Kolkata
# EMRB_LOG_LEVEL=INFO
